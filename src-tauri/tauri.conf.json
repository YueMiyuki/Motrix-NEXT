{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Motrix",
  "version": "0.0.1",
  "identifier": "app.motrix.native",
  "build": {
    "devUrl": "http://127.0.0.1:9080",
    "frontendDist": "../dist/outputs",
    "beforeDevCommand": "pnpm dev:renderer",
    "beforeBuildCommand": "pnpm pack:renderer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Motrix",
        "width": 1024,
        "height": 768,
        "minWidth": 478,
        "minHeight": 420,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true,
        "visible": false,
        "backgroundColor": [255, 255, 255, 255]
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://127.0.0.1:* http://127.0.0.1:* https://*; img-src 'self' asset: data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' blob:"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../extra/**/*"],
    "fileAssociations": [
      {
        "ext": ["torrent"],
        "mimeType": "application/x-bittorrent",
        "description": "BitTorrent file"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["mo", "motrix", "magnet", "thunder"]
      }
    },
    "updater": {
      "endpoints": ["https://motrix.app/api/update/{{target}}/{{arch}}/{{current_version}}"],
      "pubkey": ""
    }
  }
}
