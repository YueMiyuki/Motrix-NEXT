    "@vue/compat": "^3.5.30",
    "@vue/compiler-sfc": "^3.5.30",
    "@vue/eslint-config-standard": "^9.0.1",
    "ajv": "^8.18.0",
    "axios": "^1.13.6",
    "babel-loader": "^10.1.1",
    "babel-plugin-component": "^1.1.1",
    "bittorrent-peerid": "^1.3.6",
    "blob-util": "^2.0.2",
    "cfonts": "^3.3.1",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^10.1.0",
