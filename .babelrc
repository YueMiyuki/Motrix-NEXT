{
  "comments": false,
  "env": {
    "main": {
      "presets": ["@babel/preset-env", "@babel/preset-typescript"]
    },
    "renderer": {
      "presets": ["@babel/preset-env", "@babel/preset-typescript"]
    },
    "web": {
      "presets": ["@babel/preset-env", "@babel/preset-typescript"]
    }
  },
  "plugins": ["@babel/plugin-transform-class-properties", "@babel/plugin-transform-runtime"]
}
